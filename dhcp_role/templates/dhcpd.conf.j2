# {{ ansible_managed }}
option domain-name "{{ dhcp_domain_name }}";
option domain-name-servers {{ dhcp_dns_servers }};
default-lease-time {{ dhcp_default_lease_time }};
max-lease-time {{ dhcp_max_lease_time }};
ddns-update-style none;
{% if dhcp_authoritative | bool %}
authoritative;
{% endif %}

# PXE client architecture type (DHCP option 93, RFC 4578).
option arch code 93 = unsigned integer 16;

subnet {{ dhcp_subnet }} netmask {{ dhcp_netmask }} {
  range {{ dhcp_range_start }} {{ dhcp_range_end }};
  option subnet-mask {{ dhcp_netmask }};
  option routers {{ dhcp_routers }};
  option broadcast-address {{ dhcp_broadcast_address }};
  next-server {{ pxe_server_ip }};

  # Hand each client the bootloader matching its firmware.
  if option arch = 00:07 or option arch = 00:09 {
    # x86-64 UEFI
    filename "{{ pxe_bootfile_uefi }}";
  } else {
    # Legacy BIOS
    filename "{{ pxe_bootfile_bios }}";
  }
}
