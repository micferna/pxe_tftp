# {{ ansible_managed }}

# Fleet override: a machine with its own profile boots straight into it.
if [ -e /grub/host-${net_default_mac}.cfg ]; then
    configfile /grub/host-${net_default_mac}.cfg
fi

set default=0
set timeout={{ pxe_menu_timeout_seconds }}

menuentry "Install Debian" {
    linux /debian-installer/amd64/linux
    initrd /debian-installer/amd64/initrd.gz
}

menuentry "Install Ubuntu" {
    linux /ubuntu-installer/amd64/linux
    initrd /ubuntu-installer/amd64/initrd.gz
}
{% if pxe_enable_autoinstall | bool %}

menuentry "Install Debian [AUTOMATED - ERASES DISK]" {
    linux /debian-installer/amd64/linux auto=true priority=critical preseed/url=http://{{ pxe_server_ip }}/preseed/preseed-debian.cfg
    initrd /debian-installer/amd64/initrd.gz
}

menuentry "Install Ubuntu [AUTOMATED - ERASES DISK]" {
    linux /ubuntu-installer/amd64/linux auto=true priority=critical preseed/url=http://{{ pxe_server_ip }}/preseed/preseed-ubuntu.cfg
    initrd /ubuntu-installer/amd64/initrd.gz
}
{% endif %}
{% if pxe_enable_netbootxyz | bool %}

menuentry "netboot.xyz (universal menu)" {
    chainloader /netboot.xyz.efi
}
{% endif %}

menuentry "Boot from local disk" {
    exit
}
