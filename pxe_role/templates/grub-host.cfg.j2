# {{ ansible_managed }}
# Per-machine UEFI boot profile for {{ item.name }} ({{ item.mac }}).
set default=0
set timeout=1

menuentry "Install {{ item.os }} on {{ item.name }}" {
    linux /{{ item.os }}-installer/amd64/linux{% if item.autoinstall | default(false) | bool %} auto=true priority=critical preseed/url=http://{{ pxe_server_ip }}/preseed/preseed-{{ item.os }}.cfg{% endif %}

    initrd /{{ item.os }}-installer/amd64/initrd.gz
}
